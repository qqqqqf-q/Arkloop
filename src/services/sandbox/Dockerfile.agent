# syntax=docker/dockerfile:1
# sandbox-agent 容器镜像
# 用于 Docker sandbox 后端，容器内运行 sandbox-agent 以 TCP 模式监听。
#
# 构建：
#   docker build -f Dockerfile.agent -t arkloop/sandbox-agent:latest ../..
#   (从 src/services/sandbox/ 目录执行)
FROM golang:1.26-alpine AS builder
WORKDIR /workspace
COPY src/services/sandbox/go.mod src/services/sandbox/go.sum src/services/sandbox/
COPY src/services/shared/go.mod src/services/shared/go.sum src/services/shared/
RUN printf 'go 1.26.0\nuse (\n\t./src/services/sandbox\n\t./src/services/shared\n)\n' > go.work
RUN --mount=type=cache,target=/go/pkg/mod \
    go mod download
COPY src/services/sandbox src/services/sandbox
COPY src/services/shared src/services/shared
RUN --mount=type=cache,target=/go/pkg/mod \
    --mount=type=cache,target=/root/.cache/go-build \
    GOOS=linux CGO_ENABLED=0 \
    go build -ldflags="-s -w" -o /sandbox-agent ./src/services/sandbox/agent

FROM python:3.12-slim-bookworm
ARG NODE_VERSION=20.18.1
COPY src/services/sandbox/rootfs/install_guest_baseline.sh /tmp/install_guest_baseline.sh
COPY src/services/sandbox/rootfs/guest-requirements.txt /tmp/guest-requirements.txt
RUN chmod +x /tmp/install_guest_baseline.sh && /tmp/install_guest_baseline.sh && rm -f /tmp/install_guest_baseline.sh /tmp/guest-requirements.txt
# Install opencode (ACP-compatible coding agent)
# Copy binary instead of symlink so uid 1000 (arkloop) can access it
# (symlink to /root/.opencode/bin/ fails because /root is mode 700)
RUN curl -fsSL https://opencode.ai/install | bash && \
    cp /root/.opencode/bin/opencode /usr/local/bin/opencode && \
    chmod 755 /usr/local/bin/opencode && \
    rm -rf /root/.opencode
COPY --from=builder /sandbox-agent /usr/local/bin/sandbox-agent
COPY src/services/sandbox/rootfs/chart_prelude.py /usr/local/share/arkloop/chart_prelude.py
ENV SANDBOX_AGENT_LISTEN=tcp
EXPOSE 8080
WORKDIR /workspace
ENTRYPOINT ["sandbox-agent"]
