---
import { getSectionFromPath, getTopNavigation, type Locale } from '@/lib/navigation';

interface Props {
  locale: Locale;
  pathname: string;
  alternatePath?: string | null;
  hideLocaleSwitch?: boolean;
}

const { locale, pathname, alternatePath = null, hideLocaleSwitch = false } = Astro.props;
const navItems = getTopNavigation(locale);
const activeSection = getSectionFromPath(pathname);
const homeHref = locale === 'en' ? '/en' : '/';
const zhPath = locale === 'zh' ? pathname : alternatePath;
const enPath = locale === 'en' ? pathname : alternatePath;
---

<header class="topbar">
  <div class="topbar-inner">
    <a class="brand" href={homeHref}>
      <span class="brand-text">Arkloop Developers</span>
    </a>

    <nav class="topnav" aria-label="Primary">
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={['nav-link', activeSection === item.id && 'nav-link-active']}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="topbar-actions">
      <a class="topbar-icon" href="https://github.com/qqqqqf-q/Arkloop" target="_blank" rel="noreferrer" aria-label="GitHub">
        <svg width="20" height="20" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
      </a>
      {!hideLocaleSwitch && (zhPath || enPath) && (
        <div class="locale-switcher">
          <button class="topbar-icon" type="button" aria-label="Switch language" data-locale-toggle>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          </button>
          <div class="locale-dropdown" data-locale-dropdown>
            {zhPath && <a href={zhPath} class:list={['locale-option', locale === 'zh' && 'locale-option-active']}>中文</a>}
            {enPath && <a href={enPath} class:list={['locale-option', locale === 'en' && 'locale-option-active']}>English</a>}
          </div>
        </div>
      )}
      <button class="topbar-icon" type="button" data-theme-toggle aria-label="切换主题">
        <svg class="theme-icon theme-icon-light" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
        <svg class="theme-icon theme-icon-dark" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
      </button>
    </div>
  </div>
</header>

<script>
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    const toggle = target.closest('[data-locale-toggle]');
    const dropdown = document.querySelector('[data-locale-dropdown]');
    if (!dropdown) return;
    if (toggle) {
      dropdown.classList.toggle('locale-dropdown-open');
    } else if (!target.closest('.locale-dropdown')) {
      dropdown.classList.remove('locale-dropdown-open');
    }
  });
</script>
