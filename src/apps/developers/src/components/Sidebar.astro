---
import type { SidebarGroup } from '@/lib/navigation';

interface Props {
  groups: SidebarGroup[];
  pathname: string;
  title: string;
}

const { groups, pathname, title } = Astro.props;
---

<aside class="sidebar-shell">
  <div class="sidebar-sticky">
    <div class="sidebar-header">
      <button class="sidebar-search" type="button" data-search-open>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <span>Search</span>
      </button>
      <h2>{title}</h2>
    </div>

    {groups.map((group) => (
      <section class="sidebar-group">
        <h3>{group.label}</h3>
        <div class="sidebar-links">
          {group.items.map((item) => (
            <a href={item.href} class:list={['sidebar-link', pathname === item.href && 'sidebar-link-active']}>
              {item.label}
            </a>
          ))}
        </div>
      </section>
    ))}
  </div>
</aside>
