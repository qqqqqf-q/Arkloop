---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
const visibleHeadings = headings.filter((heading) => heading.depth >= 2 && heading.depth <= 3);
---

{visibleHeadings.length > 0 && (
  <aside class="toc-shell">
    <div class="toc-sticky">
      <nav class="toc-links">
        {visibleHeadings.map((heading) => (
          <a href={`#${heading.slug}`} class:list={['toc-link', heading.depth === 3 && 'toc-link-child']}>
            {heading.text}
          </a>
        ))}
      </nav>
    </div>
  </aside>
)}

<script is:inline>
  (() => {
    const tocLinks = document.querySelectorAll('.toc-link');
    if (!tocLinks.length) return;

    const headings = [];
    tocLinks.forEach((link) => {
      const href = link.getAttribute('href');
      if (href) {
        const el = document.querySelector(href);
        if (el) headings.push({ el, link });
      }
    });

    if (!headings.length) return;

    const update = () => {
      let active = headings[0];
      for (const h of headings) {
        if (h.el.getBoundingClientRect().top <= 100) {
          active = h;
        }
      }
      tocLinks.forEach((l) => l.classList.remove('toc-link-active'));
      if (active) active.link.classList.add('toc-link-active');
    };

    window.addEventListener('scroll', update, { passive: true });
    update();
  })();
</script>
