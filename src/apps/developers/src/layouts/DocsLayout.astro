---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PrevNextNav from '@/components/PrevNextNav.astro';
import Sidebar from '@/components/Sidebar.astro';
import TableOfContents from '@/components/TableOfContents.astro';
import { getSidebar, type Locale } from '@/lib/navigation';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface LinkItem {
  label: string;
  href: string;
}

interface Props {
  title: string;
  description?: string;
  locale: Locale;
  pathname: string;
  section: 'docs' | 'api';
  headings: Heading[];
  prev?: LinkItem | null;
  next?: LinkItem | null;
  showSyntheticTitle?: boolean;
  alternatePath?: string | null;
}

const {
  title,
  description,
  locale,
  pathname,
  section,
  headings,
  prev = null,
  next = null,
  showSyntheticTitle = false,
  alternatePath = null,
} = Astro.props;

const sidebar = getSidebar(locale, section);
const sidebarTitle = section === 'api' ? 'API Reference' : locale === 'en' ? 'Documentation' : '工程文档';
---

<BaseLayout
  title={title}
  description={description}
  locale={locale}
  pathname={pathname}
  alternatePath={alternatePath}
>
  <div class="docs-shell">
    <Sidebar groups={sidebar} pathname={pathname} title={sidebarTitle} />

    <article class="content-shell" data-docs-scroll-root>
      <header class="content-header">
        {showSyntheticTitle && <h1>{title}</h1>}
        {description && <p class="content-description">{description}</p>}
      </header>
      <div class="doc-content">
        <slot />
      </div>
      <PrevNextNav prev={prev} next={next} locale={locale} />
    </article>

    <TableOfContents headings={headings} />
  </div>
</BaseLayout>
