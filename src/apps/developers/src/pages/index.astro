---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Arkloop Developers" description="Arkloop 开发者门户 -- 干净、强大、属于你的 AI Agent 平台。" locale="zh" pathname="/" alternatePath="/en">
  <div class="landing-wrap">
    <div class="landing-card">

      <!-- 左侧：SVG 字体展示 -->
      <div class="split-left">
        <div class="type-specimen" aria-label="Arkloop">
          <svg class="type-svg" viewBox="0 0 526 210" fill="none" xmlns="http://www.w3.org/2000/svg">
            <!--
              Ark: Inter 600, 120px, x=95, baseline y=100
              loop: Inter 400, 82px, x=217, baseline y=190
              外层 translate(6)：整块再微调右移，viewBox 右扩以容纳
            -->
            <g transform="translate(6, 0)">

            <!-- === Ark 辅助线 === -->
            <line x1="0" y1="15" x2="520" y2="15" stroke="var(--guide-line)" stroke-width="0.7" />
            <text x="516" y="12" fill="var(--guide-label)" font-size="7" font-family="ui-monospace, monospace" text-anchor="end">cap height</text>

            <line x1="0" y1="100" x2="520" y2="100" stroke="var(--guide-line)" stroke-width="0.7" />
            <text x="516" y="97" fill="var(--guide-label)" font-size="7" font-family="ui-monospace, monospace" text-anchor="end">baseline</text>

            <!-- Ark 垂直线 -->
            <line x1="95" y1="6" x2="95" y2="108" stroke="var(--guide-line)" stroke-width="0.4" />
            <line x1="180" y1="6" x2="180" y2="108" stroke="var(--guide-line)" stroke-width="0.4" />
            <line x1="220" y1="6" x2="220" y2="108" stroke="var(--guide-line)" stroke-width="0.4" />
            <line x1="270" y1="6" x2="270" y2="108" stroke="var(--guide-line)" stroke-width="0.4" />
            <line x1="340" y1="6" x2="340" y2="108" stroke="var(--guide-line)" stroke-width="0.4" />

            <!-- A 三角构造 -->
            <line x1="137" y1="15" x2="97" y2="100" stroke="var(--construct-line)" stroke-width="0.7" stroke-dasharray="3 3" />
            <line x1="137" y1="15" x2="177" y2="100" stroke="var(--construct-line)" stroke-width="0.7" stroke-dasharray="3 3" />
            <circle cx="137" cy="15" r="2.5" fill="var(--guide-dot)" />
            <line x1="113" y1="65" x2="161" y2="65" stroke="var(--construct-line)" stroke-width="0.5" stroke-dasharray="2 2" />

            <!-- k 对角构造 -->
            <line x1="283" y1="58" x2="332" y2="15" stroke="var(--construct-line)" stroke-width="0.6" stroke-dasharray="3 3" />
            <line x1="283" y1="58" x2="337" y2="100" stroke="var(--construct-line)" stroke-width="0.6" stroke-dasharray="3 3" />
            <circle cx="283" cy="58" r="2" fill="var(--guide-dot)" />

            <!-- Ark 高度标注 -->
            <line x1="118" y1="15" x2="118" y2="100" stroke="var(--dimension-line)" stroke-width="0.5" />
            <line x1="116" y1="15" x2="121" y2="15" stroke="var(--dimension-line)" stroke-width="0.5" />
            <line x1="116" y1="100" x2="121" y2="100" stroke="var(--dimension-line)" stroke-width="0.5" />
            <text x="118" y="61" fill="var(--guide-label)" font-size="6.5" font-family="ui-monospace, monospace" text-anchor="middle" transform="rotate(-90, 118, 61)">87</text>

            <!-- 行间距标注 -->
            <line x1="385" y1="100" x2="385" y2="130" stroke="var(--dimension-line)" stroke-width="0.5" stroke-dasharray="2 4" />
            <line x1="382" y1="100" x2="388" y2="100" stroke="var(--dimension-line)" stroke-width="0.5" />
            <line x1="382" y1="130" x2="388" y2="130" stroke="var(--dimension-line)" stroke-width="0.5" />
            <text x="394" y="118" fill="var(--guide-label)" font-size="6.5" font-family="ui-monospace, monospace">30</text>

            <!-- === loop 辅助线 === -->
            <line x1="202" y1="130" x2="520" y2="130" stroke="var(--guide-line)" stroke-width="0.5" stroke-dasharray="3 4" />
            <text x="516" y="127" fill="var(--guide-label)" font-size="7" font-family="ui-monospace, monospace" text-anchor="end">ascender</text>

            <line x1="202" y1="147" x2="520" y2="147" stroke="var(--guide-line)" stroke-width="0.6" stroke-dasharray="2 3" />
            <text x="516" y="144" fill="var(--guide-label)" font-size="7" font-family="ui-monospace, monospace" text-anchor="end">x-height</text>

            <line x1="202" y1="190" x2="520" y2="190" stroke="var(--guide-line)" stroke-width="0.7" />
            <text x="516" y="187" fill="var(--guide-label)" font-size="7" font-family="ui-monospace, monospace" text-anchor="end">baseline</text>

            <line x1="202" y1="208" x2="520" y2="208" stroke="var(--guide-line)" stroke-width="0.5" stroke-dasharray="3 4" />
            <text x="516" y="205" fill="var(--guide-label)" font-size="7" font-family="ui-monospace, monospace" text-anchor="end">descender</text>

            <!-- loop 垂直线 -->
            <line x1="217" y1="122" x2="217" y2="196" stroke="var(--guide-line)" stroke-width="0.4" />
            <line x1="272" y1="140" x2="272" y2="196" stroke="var(--guide-line)" stroke-width="0.4" />
            <line x1="342" y1="140" x2="342" y2="196" stroke="var(--guide-line)" stroke-width="0.4" />
            <line x1="410" y1="140" x2="410" y2="210" stroke="var(--guide-line)" stroke-width="0.4" />
            <line x1="477" y1="140" x2="477" y2="210" stroke="var(--guide-line)" stroke-width="0.4" />

            <!-- l 端点 -->
            <circle cx="227" cy="130" r="2" fill="var(--guide-dot)" />
            <circle cx="227" cy="190" r="2" fill="var(--guide-dot)" />

            <!-- o1 -->
            <circle cx="307" cy="168" r="23" stroke="var(--construct-line)" stroke-width="0.7" stroke-dasharray="3 3" />
            <circle cx="307" cy="168" r="2" fill="var(--guide-dot)" />
            <line x1="307" y1="142" x2="307" y2="194" stroke="var(--construct-line)" stroke-width="0.4" />
            <line x1="281" y1="168" x2="333" y2="168" stroke="var(--construct-line)" stroke-width="0.4" />

            <!-- 字距标注: A-r -->
            <line x1="210" y1="108" x2="250" y2="108" stroke="var(--dimension-line)" stroke-width="0.5" />
            <line x1="210" y1="106" x2="210" y2="111" stroke="var(--dimension-line)" stroke-width="0.5" />
            <line x1="250" y1="106" x2="250" y2="111" stroke="var(--dimension-line)" stroke-width="0.5" />
            <text x="230" y="117" fill="var(--guide-label)" font-size="6" font-family="ui-monospace, monospace" text-anchor="middle">40</text>

            <!-- === 文字 === -->
            <text
              x="95"
              y="100"
              fill="var(--text-strong)"
              font-size="120"
              font-family="Inter, ui-sans-serif, system-ui, sans-serif"
              font-weight="600"
              letter-spacing="-0.04em"
            >Ark</text>

            <text
              x="217"
              y="190"
              fill="var(--text-strong)"
              font-size="82"
              font-family="Inter, ui-sans-serif, system-ui, sans-serif"
              font-weight="400"
              letter-spacing="-0.03em"
            >loop</text>
            </g>
          </svg>
        </div>
      </div>

      <!-- 右侧：内容区 -->
      <div class="split-right">
        <h1 class="hero-title">Arkloop：统一的 AI Agent 平台</h1>
        <p class="hero-desc">构建、部署并管理强大的 AI Agent。简洁、安全、以开发者为先。</p>

        <div class="cta-block">
          <div class="btn-download-wrap">
            <a class="btn-download" id="btn-download-zh" href="https://github.com/qqqqqf-q/Arkloop/releases">
              <span class="btn-download-text">Download for Desktop</span>
            </a>
            <div class="btn-platform-divider"></div>
            <div class="btn-platform-trigger" id="platform-trigger-zh" title="切换平台">
              <span class="btn-platform-label" id="platform-label-zh">Apple Silicon</span>
              <svg class="btn-platform-chevron" viewBox="0 0 10 6" fill="none">
                <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <select class="platform-select-overlay" id="platform-select-zh" aria-label="选择平台">
                <option value="darwin-arm64">macOS Apple Silicon</option>
                <option value="darwin-x64">macOS Intel</option>
                <option value="win32-x64">Windows x64</option>
                <option value="linux-x64">Linux x64</option>
              </select>
            </div>
          </div>
          <a class="link-docs" href="/docs/guide">快速开始 &amp; 文档</a>
        </div>

        <div class="feat-grid">
          <!-- Agent Loop -->
          <div class="feat-item">
            <svg class="feat-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
            </svg>
            <h3 class="feat-title">Agent Loop</h3>
            <p class="feat-desc">多步自主执行，规则、推理与工具编排。跨会话持久化记忆。</p>
          </div>
          <!-- Multi-Model -->
          <div class="feat-item">
            <svg class="feat-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <circle cx="12" cy="12" r="3"/><circle cx="12" cy="12" r="8"/>
              <line x1="12" y1="2" x2="12" y2="4"/><line x1="12" y1="20" x2="12" y2="22"/>
              <line x1="2" y1="12" x2="4" y2="12"/><line x1="20" y1="12" x2="22" y2="12"/>
            </svg>
            <h3 class="feat-title">Multi-Model</h3>
            <p class="feat-desc">OpenAI、Anthropic 及任何兼容接口。优先级路由，自动限流处理。</p>
          </div>
          <!-- Sandbox -->
          <div class="feat-item">
            <svg class="feat-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="3" y="3" width="18" height="18" rx="2" stroke-dasharray="4 2"/>
              <line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="3" x2="9" y2="9"/>
            </svg>
            <h3 class="feat-title">Sandbox</h3>
            <p class="feat-desc">Firecracker 微虚拟机或 Docker 隔离环境。代码执行，严格资源限制。</p>
          </div>
          <!-- Security -->
          <div class="feat-item">
            <svg class="feat-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
            <h3 class="feat-title">Security</h3>
            <p class="feat-desc">语义级 Prompt 注入扫描。检测并拦截攻击，保护 Agent 运行安全。</p>
          </div>
          <!-- Channels -->
          <div class="feat-item">
            <svg class="feat-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 015.19 12.7 19.79 19.79 0 012.12 4.07 2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
            </svg>
            <h3 class="feat-title">Channels</h3>
            <p class="feat-desc">将 Agent 接入 Telegram，完整媒体处理与群组上下文支持。</p>
          </div>
          <!-- REST + SSE -->
          <div class="feat-item">
            <svg class="feat-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <circle cx="12" cy="12" r="10"/><path d="M2 12h20"/>
              <path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/>
            </svg>
            <h3 class="feat-title">REST + SSE</h3>
            <p class="feat-desc">40+ 端点覆盖线程、运行、Personas 与模型供应商。游标续传。</p>
          </div>
        </div>
      </div>

    </div>
  </div>
</BaseLayout>

<script>
  const RELEASES_API = 'https://api.github.com/repos/qqqqqf-q/Arkloop/releases/latest';
  const RELEASES_PAGE = 'https://github.com/qqqqqf-q/Arkloop/releases';

  // 平台关键词 -> asset 文件名片段映射（按项目实际命名调整）
  const PLATFORM_PATTERNS: Record<string, string[]> = {
    'darwin-arm64': ['darwin-arm64', 'mac-arm64', 'macos-arm64', 'arm64.dmg', 'arm64.zip'],
    'darwin-x64':   ['darwin-x64', 'mac-x64', 'macos-x64', 'x64.dmg', 'intel.dmg'],
    'win32-x64':    ['win32-x64', 'windows-x64', 'win-x64', '.exe', 'setup.exe'],
    'linux-x64':    ['linux-x64', 'linux-amd64', 'amd64.AppImage', 'linux-x86_64'],
  };

  function detectPlatform(): string {
    const ua = navigator.userAgent;
    const platform = navigator.platform || '';
    if (platform.startsWith('Mac') || ua.includes('Mac OS X')) {
      // Apple Silicon: macOS 11+ 上的 arm64，无法从 UA 精确判断，尝试 canvas trick
      // 保守做法：检查 navigator.userAgentData (Chrome/Edge) 或回退到 arm64 优先
      const uad = (navigator as any).userAgentData;
      if (uad && uad.getHighEntropyValues) {
        // async，先返回 auto，异步更新
        uad.getHighEntropyValues(['architecture']).then((data: any) => {
          if (data.architecture === 'arm') updatePlatform('darwin-arm64');
          else updatePlatform('darwin-x64');
        }).catch(() => updatePlatform('darwin-arm64'));
        return 'darwin-arm64'; // 默认 Apple Silicon
      }
      return 'darwin-arm64';
    }
    if (platform.startsWith('Win') || ua.includes('Windows')) return 'win32-x64';
    if (ua.includes('Linux')) return 'linux-x64';
    return 'darwin-arm64';
  }

  const PLATFORM_LABELS: Record<string, string> = {
    'darwin-arm64': 'Apple Silicon',
    'darwin-x64':   'macOS Intel',
    'win32-x64':    'Windows',
    'linux-x64':    'Linux',
  };

  let releaseAssets: Array<{ name: string; browser_download_url: string }> = [];
  let currentPlatform = detectPlatform();

  function findAsset(platform: string) {
    const patterns = PLATFORM_PATTERNS[platform] ?? [];
    return releaseAssets.find(a =>
      patterns.some(p => a.name.toLowerCase().includes(p.toLowerCase()))
    );
  }

  function updatePlatform(platform: string) {
    currentPlatform = platform;
    const btn = document.getElementById('btn-download-zh') as HTMLAnchorElement | null;
    const label = document.getElementById('platform-label-zh');
    const sel = document.getElementById('platform-select-zh') as HTMLSelectElement | null;
    if (label) label.textContent = PLATFORM_LABELS[platform] ?? platform;
    if (sel) sel.value = platform;
    if (btn) {
      const asset = findAsset(platform);
      btn.href = asset ? asset.browser_download_url : RELEASES_PAGE;
    }
  }

  async function initDownload() {
    try {
      const res = await fetch(RELEASES_API);
      if (!res.ok) return;
      const data = await res.json();
      releaseAssets = data.assets ?? [];
    } catch {
      // 网络失败，保持指向 releases 页面
    }
    updatePlatform(currentPlatform);
  }

  // 平台选择器变化
  const sel = document.getElementById('platform-select-zh') as HTMLSelectElement | null;
  if (sel) {
    sel.addEventListener('change', () => updatePlatform(sel.value));
  }

  // 点击主按钮区域触发下载
  const downloadBtn = document.getElementById('btn-download-zh') as HTMLAnchorElement | null;
  if (downloadBtn) {
    downloadBtn.addEventListener('click', (e) => {
      // 如果点击在 platform trigger 区域内，阻止跳转（由 select 处理）
      const trigger = document.getElementById('platform-trigger-zh');
      if (trigger && trigger.contains(e.target as Node)) {
        e.preventDefault();
      }
    });
  }

  initDownload();
</script>

<style>
  :root {
    --guide-line: rgba(255, 255, 255, 0.22);
    --guide-dot: rgba(255, 255, 255, 0.35);
    --guide-label: rgba(255, 255, 255, 0.25);
    --construct-line: rgba(255, 255, 255, 0.15);
    --dimension-line: rgba(255, 255, 255, 0.18);
  }

  :root[data-theme='light'] {
    --guide-line: rgba(0, 0, 0, 0.22);
    --guide-dot: rgba(0, 0, 0, 0.35);
    --guide-label: rgba(0, 0, 0, 0.25);
    --construct-line: rgba(0, 0, 0, 0.15);
    --dimension-line: rgba(0, 0, 0, 0.18);
  }

  /* 页面级容器：垂直居中，限制宽度 */
  .landing-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(100vh - 60px);
    padding: 32px 24px;
  }

  /* 卡片：有描边，限制最大宽度 */
  .landing-card {
    display: flex;
    width: 100%;
    max-width: 860px;
    border: 1px solid var(--border-strong);
    border-radius: 16px;
    overflow: hidden;
    min-height: 520px;
  }

  .split-left {
    flex: 0 0 44%;
    display: flex;
    align-items: center;
    justify-content: center;
    border-right: 1px solid var(--border-primary);
    background: var(--bg-surface-soft);
    padding: 40px 32px;
  }

  .type-specimen {
    width: 100%;
    max-width: 380px;
  }

  .type-svg {
    width: 100%;
    height: auto;
  }

  .split-right {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 40px 44px;
    gap: 20px;
  }

  .hero-title {
    margin: 0;
    font-size: clamp(1.6rem, 2.4vw, 2.4rem);
    font-weight: 700;
    letter-spacing: -0.04em;
    color: var(--text-strong);
    line-height: 1.15;
  }

  .hero-desc {
    margin: 0;
    font-size: 0.9rem;
    line-height: 1.7;
    color: var(--text-secondary);
  }

  .cta-block {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 10px;
  }

  /* Download 行：按钮 + 平台选择器 */
  .download-row {
    display: flex;
    align-items: center;
    gap: 8px;
    width: 100%;
  }

  .btn-download {
    flex: 1;
    display: block;
    padding: 13px 20px;
    background: var(--accent);
    color: var(--accent-contrast);
    font-size: 0.95rem;
    font-weight: 700;
    border-radius: 10px;
    text-align: center;
    transition: opacity 140ms ease;
    white-space: nowrap;
  }

  .btn-download:hover {
    opacity: 0.88;
  }

  /* 平台选择器 */
  .platform-picker {
    display: flex;
    align-items: center;
    position: relative;
  }

  .platform-btn {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 0 10px;
    height: 44px;
    background: transparent;
    border: 1px solid var(--border-strong);
    border-radius: 10px;
    cursor: pointer;
    color: var(--text-secondary);
    font-size: 0.78rem;
    white-space: nowrap;
    position: relative;
  }

  .platform-btn:hover {
    color: var(--text-primary);
    border-color: var(--border-strong);
  }

  /* select 透明覆盖在 button 上 */
  .platform-select {
    position: absolute;
    inset: 0;
    opacity: 0;
    cursor: pointer;
    width: 100%;
    height: 100%;
  }

  .link-docs {
    font-size: 0.85rem;
    color: #3b82f6;
    text-decoration: none;
    padding-left: 2px;
  }

  .link-docs:hover {
    color: #60a5fa;
  }

  .feat-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px 20px;
    margin-top: 2px;
  }

  .feat-item {
    display: flex;
    flex-direction: column;
    gap: 5px;
  }

  .feat-icon {
    width: 22px;
    height: 22px;
    color: var(--text-secondary);
    flex-shrink: 0;
  }

  .feat-title {
    margin: 0;
    font-size: 0.84rem;
    font-weight: 600;
    color: var(--text-strong);
  }

  .feat-desc {
    margin: 0;
    font-size: 0.75rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  @media (max-width: 767px) {
    .landing-wrap {
      padding: 16px;
      align-items: flex-start;
    }

    .landing-card {
      flex-direction: column;
      min-height: unset;
    }

    .split-left {
      flex: none;
      border-right: none;
      border-bottom: 1px solid var(--border-primary);
      padding: 28px 24px;
    }

    .split-right {
      flex: none;
      padding: 28px 24px;
    }

    .feat-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .download-row {
      flex-wrap: wrap;
    }

    .btn-download {
      flex: none;
      width: 100%;
    }
  }
</style>
