          <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" fill="currentColor" stroke="none"/>
        </svg>
        <div>
          <h2 class="contrib-title">贡献</h2>
          <p class="contrib-desc">我们欢迎所有形式的贡献。即使你不是开发者，只是一个普通用户 -- 如果你在使用中感到任何不舒服的地方，哪怕只是一点间距、一个颜色、一个很小很小的细节，或者是一个很大很大的方向，都可以直接开一个 issue。我们认真对待每一个体验细节，你的反馈会让所有人的体验变得更好。</p>
        </div>
      </div>
      <div class="contrib-actions">
        <a class="contrib-btn contrib-btn-primary" href="https://github.com/qqqqqf-q/Arkloop" target="_blank" rel="noopener">GitHub</a>
        <a class="contrib-btn contrib-btn-secondary" href="/docs/contributing">贡献指南</a>
      </div>
    </div>

    <!-- 第三区：使用方式 -->
    <div class="section-grid">
      <div class="section-card">
        <div class="section-card-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <rect x="2" y="3" width="20" height="14" rx="2"/>
            <path d="M8 21h8M12 17v4"/>
          </svg>
        </div>
        <h2 class="section-card-title">桌面应用</h2>
        <p class="section-card-desc">基于 Electron + Go Sidecar 的原生应用，完全本地运行。内置完整运行环境 -- 无需 Docker，无需配置，打开即用。通过 GitHub Releases 自动更新。</p>
        <div class="section-card-platforms">
          <span>macOS</span>
          <span>Linux</span>
          <span>Windows</span>
        </div>
      </div>
      <div class="section-card">
        <div class="section-card-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/>
            <polyline points="3.27 6.96 12 12.01 20.73 6.96"/>
            <line x1="12" y1="22.08" x2="12" y2="12"/>
          </svg>
        </div>
        <h2 class="section-card-title">自托管部署</h2>
        <p class="section-card-desc">完整的服务器端部署方案。Docker Compose 一键启动，预构建镜像支持生产环境。需要 2+ CPU 核心，4+ GiB 内存。</p>
        <div class="section-code">
          <code>./setup.sh install</code>
        </div>
      </div>
      <div class="section-card">
        <div class="section-card-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <circle cx="12" cy="12" r="3"/>
            <path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/>
          </svg>
        </div>
        <h2 class="section-card-title">技能生态</h2>
        <p class="section-card-desc">从 ClawHub 搜索与导入技能，兼容 OpenClaw SKILL.md 格式。自定义 Persona 支持独立系统提示词、工具集和 Lua 脚本自定义 Agent Loop。</p>
        <a class="section-card-link" href="/docs/skills">了解技能生态</a>
      </div>
    </div>

  </div>
</BaseLayout>

<script>
  const RELEASES_API = 'https://api.github.com/repos/qqqqqf-q/Arkloop/releases/latest';
  const RELEASES_PAGE = 'https://github.com/qqqqqf-q/Arkloop/releases';

  const PLATFORM_PATTERNS: Record<string, string[]> = {
    'darwin-arm64': ['darwin-arm64', 'mac-arm64', 'macos-arm64', 'arm64.dmg', 'arm64.zip'],
    'darwin-x64':   ['darwin-x64', 'mac-x64', 'macos-x64', 'x64.dmg', 'intel.dmg'],
    'win32-x64':    ['win32-x64', 'windows-x64', 'win-x64', '.exe', 'setup.exe'],
    'linux-x64':    ['linux-x64', 'linux-amd64', 'amd64.AppImage', 'linux-x86_64'],
  };

  const PLATFORM_LABELS: Record<string, string> = {
    'darwin-arm64': 'Mac · Apple Silicon',
    'darwin-x64':   'Mac · Intel',
    'win32-x64':    'Windows · x64',
    'linux-x64':    'Linux · x64',
  };

  function detectPlatform(): string {
    const ua = navigator.userAgent;
    const platform = navigator.platform || '';
    if (platform.startsWith('Mac') || ua.includes('Mac OS X')) {
      const uad = (navigator as any).userAgentData;
      if (uad && uad.getHighEntropyValues) {
        uad.getHighEntropyValues(['architecture']).then((data: any) => {
          if (data.architecture === 'arm') updatePlatform('darwin-arm64');
          else updatePlatform('darwin-x64');
        }).catch(() => updatePlatform('darwin-arm64'));
        return 'darwin-arm64';
      }
      return 'darwin-arm64';
    }
    if (platform.startsWith('Win') || ua.includes('Windows')) return 'win32-x64';
    if (ua.includes('Linux')) return 'linux-x64';
    return 'darwin-arm64';
  }

  let releaseAssets: Array<{ name: string; browser_download_url: string }> = [];
  let currentPlatform = detectPlatform();

  function findAsset(platform: string) {
    const patterns = PLATFORM_PATTERNS[platform] ?? [];
    return releaseAssets.find(a =>
      patterns.some(p => a.name.toLowerCase().includes(p.toLowerCase()))
    );
  }

  function updatePlatform(platform: string) {
    currentPlatform = platform;
    const btn = document.getElementById('btn-download-zh') as HTMLAnchorElement | null;
    const label = document.getElementById('platform-label-zh');
    if (label) label.textContent = PLATFORM_LABELS[platform] ?? platform;
    document.querySelectorAll('#platform-dropdown-zh .platform-option').forEach(el => {
      const opt = el as HTMLButtonElement;
      opt.setAttribute('aria-selected', opt.dataset.value === platform ? 'true' : 'false');
    });
    if (btn) {
      const asset = findAsset(platform);
      btn.href = asset ? asset.browser_download_url : RELEASES_PAGE;
    }
  }

  async function initDownload() {
    try {
      const res = await fetch(RELEASES_API);
      if (!res.ok) return;
      const data = await res.json();
      releaseAssets = data.assets ?? [];
    } catch {
      // 网络失败，保持指向 releases 页面
    }
    updatePlatform(currentPlatform);
  }

  const trigger = document.getElementById('platform-trigger-zh');
  const dropdown = document.getElementById('platform-dropdown-zh');
  const wrap = document.getElementById('btn-wrap-zh');

  if (trigger && dropdown) {
    trigger.addEventListener('click', (e) => {
      e.stopPropagation();
      const isOpen = dropdown.classList.contains('open');
      dropdown.classList.toggle('open', !isOpen);
      trigger.setAttribute('aria-expanded', String(!isOpen));
    });

    dropdown.querySelectorAll('.platform-option').forEach(el => {
      el.addEventListener('click', (e) => {
        e.stopPropagation();
        const val = (el as HTMLButtonElement).dataset.value;
        if (val) updatePlatform(val);
        dropdown.classList.remove('open');
        trigger.setAttribute('aria-expanded', 'false');
      });
    });

    document.addEventListener('click', (e) => {
      if (wrap && !wrap.contains(e.target as Node)) {
        dropdown.classList.remove('open');
        trigger.setAttribute('aria-expanded', 'false');
      }
    });
  }

  // downloadBtn 点击：如果点在 trigger 区域内则不跳转（由上面的 e.preventDefault 处理）

  initDownload();
</script>

<style>
  :root {
    --guide-line: rgba(255, 255, 255, 0.22);
    --guide-dot: rgba(255, 255, 255, 0.35);
    --guide-label: rgba(255, 255, 255, 0.25);
    --construct-line: rgba(255, 255, 255, 0.15);
    --dimension-line: rgba(255, 255, 255, 0.18);
    --split-left-bg: var(--bg-surface-soft);
    --card-bg: transparent;
  }

  :root[data-theme='light'] {
    --guide-line: rgba(0, 0, 0, 0.22);
    --guide-dot: rgba(0, 0, 0, 0.35);
    --guide-label: rgba(0, 0, 0, 0.25);
    --construct-line: rgba(0, 0, 0, 0.15);
    --dimension-line: rgba(0, 0, 0, 0.18);
    --split-left-bg: #F5F7F6;
    --card-bg: #F5F7F6;
  }

  @keyframes dropdown-slide-in {
    from { opacity: 0; transform: translateX(-50%) translateY(-4px); }
    to   { opacity: 1; transform: translateX(-50%) translateY(0); }
  }

  .landing-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 40px 24px 64px;
    gap: 20px;
  }

  /* Hero card */
  .landing-card {
    display: flex;
    width: 100%;
    max-width: 1080px;
    border: 1px solid var(--border-strong);
    border-radius: 16px;
    overflow: hidden;
    min-height: 520px;
  }

  .split-left {
    flex: 0 0 42%;
    display: flex;
    align-items: center;
    justify-content: center;
