---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Arkloop Developers" description="Arkloop developer portal -- AI agents, without the clutter." locale="en" pathname="/en" alternatePath="/">
  <div class="landing-wrap">

    <!-- Hero -->
    <section class="hero">
      <h1 class="hero-title">
        Clean, powerful AI agents.<br />Yours to own.
      </h1>

      <p class="hero-desc">Your personal AI runtime -- tool execution, memory, sandboxed code, and multi-model routing, all running on your own device.</p>

      <div class="hero-actions">
        <div class="dl-btn-wrap">
          <button class="btn-primary" id="dl-main-en">
            <span id="dl-main-label-en">Get Arkloop</span>
            <svg class="dl-chevron" viewBox="0 0 10 6" fill="none"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
          <div class="dl-dropdown" id="dl-dropdown-en">
            <a class="dl-option" href="https://github.com/qqqqqf-q/Arkloop/releases/latest/download/Arkloop-mac-arm64.dmg">
              <svg class="dl-opt-icon" viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
              macOS (Apple Silicon)
            </a>
            <a class="dl-option" href="https://github.com/qqqqqf-q/Arkloop/releases/latest/download/Arkloop-mac-x64.dmg">
              <svg class="dl-opt-icon" viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
              macOS (Intel)
            </a>
            <a class="dl-option" href="https://github.com/qqqqqf-q/Arkloop/releases/latest/download/Arkloop-win-x64.exe">
              <svg class="dl-opt-icon" viewBox="0 0 24 24" fill="currentColor"><path d="M3 12V6.75l6-1.32v6.57H3zM20 3v8.75h-8V4.38L20 3zM3 13h6v6.43l-6-1.33V13zm17 .25V22l-8-1.42V13.25h8z"/></svg>
              Windows (x64)
            </a>
            <a class="dl-option" href="https://github.com/qqqqqf-q/Arkloop/releases/latest/download/Arkloop-linux-x86_64.AppImage">
              <svg class="dl-opt-icon" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 14H9V8h2v8zm4 0h-2V8h2v8z"/></svg>
              Linux (x64)
            </a>
          </div>
        </div>
        <a class="btn-secondary" href="/en/docs">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
          Docs
        </a>
      </div>

      <div class="hero-meta">
        <a class="meta-link" href="https://github.com/qqqqqf-q/Arkloop" target="_blank" rel="noopener">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>
          GitHub
        </a>
        <a class="meta-link" href="https://t.me/Arkloop_io" target="_blank" rel="noopener">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.562 8.248l-1.97 9.289c-.145.658-.537.818-1.084.508l-3-2.21-1.447 1.394c-.16.16-.295.295-.605.295l.213-3.053 5.56-5.023c.242-.213-.054-.333-.373-.12L6.514 14.51l-2.948-.924c-.64-.203-.654-.64.136-.95l11.52-4.44c.534-.194 1.001.13.34.052z"/></svg>
          Telegram
        </a>
      </div>
    </section>

    <!-- Showcase placeholder -->
    <section class="showcase">
      <div class="showcase-frame">
        <div class="showcase-placeholder">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.3"><polygon points="5 3 19 12 5 21 5 3"/></svg>
        </div>
      </div>
    </section>

    <!-- Contributing -->
    <div class="contrib-card">
      <div class="contrib-left">
        <svg class="contrib-icon" viewBox="0 0 24 24" fill="currentColor" stroke="none">
          <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
        </svg>
        <div>
          <h2 class="contrib-title">Contributing</h2>
          <p class="contrib-desc">We welcome contributions of all kinds. Even if you're not a developer -- if something feels off, a bit of spacing, a color that doesn't sit right, any tiny detail or even a big-picture direction -- please open an issue. We take every UX detail seriously, and your feedback makes Arkloop better for everyone.</p>
        </div>
      </div>
      <div class="contrib-actions">
        <a class="contrib-btn contrib-btn-primary" href="https://github.com/qqqqqf-q/Arkloop" target="_blank" rel="noopener">GitHub</a>
        <a class="contrib-btn contrib-btn-secondary" href="/en/docs/contributing">Contributing Guide</a>
      </div>
    </div>

  </div>
</BaseLayout>

<script>
  const mainBtn = document.getElementById('dl-main-en');
  const dropdown = document.getElementById('dl-dropdown-en');
  if (mainBtn && dropdown) {
    mainBtn.addEventListener('click', () => {
      dropdown.classList.toggle('dl-dropdown-open');
    });
    document.addEventListener('click', (e) => {
      if (!mainBtn.contains(e.target as Node) && !dropdown.contains(e.target as Node)) {
        dropdown.classList.remove('dl-dropdown-open');
      }
    });
  }
</script>

<style>
  .landing-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 80px 24px 64px;
    max-width: 960px;
    margin: 0 auto;
  }

  /* Hero */
  .hero {
    width: 100%;
    padding: 40px 0 0;
  }

  .hero-title {
    margin: 0 0 20px;
    font-size: clamp(2.2rem, 5vw, 3.4rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.12;
    color: var(--text-strong);
  }

  .hero-desc {
    margin: 0 0 32px;
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--text-secondary);
    max-width: 680px;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    margin-bottom: 28px;
  }

  /* Buttons */
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 28px;
    background: var(--accent);
    color: var(--accent-contrast);
    font-size: 0.92rem;
    font-weight: 600;
    border-radius: 8px;
    border: none;
    cursor: pointer;
    transition: opacity 140ms ease;
  }

  .btn-primary:hover {
    opacity: 0.85;
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    font-size: 0.92rem;
    font-weight: 500;
    border-radius: 8px;
    border: 1px solid var(--border-strong);
    color: var(--text-secondary);
    text-decoration: none;
    transition: background 120ms ease, color 120ms ease;
  }

  .btn-secondary:hover {
    background: var(--bg-surface-soft);
    color: var(--text-strong);
  }

  .dl-chevron {
    width: 10px;
    height: 10px;
    opacity: 0.7;
    flex-shrink: 0;
  }

  /* Download dropdown */
  .dl-btn-wrap {
    position: relative;
    display: inline-flex;
  }

  .dl-dropdown {
    display: none;
    position: absolute;
    top: calc(100% + 8px);
    left: 0;
    min-width: 240px;
    background: var(--bg-elevated);
    border: 1px solid var(--border-strong);
    border-radius: 10px;
    padding: 6px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.24);
    z-index: 100;
  }

  .dl-dropdown-open {
    display: block;
    animation: dl-slide-down 0.1s ease-out;
  }

  @keyframes dl-slide-down {
    from { opacity: 0; transform: translateY(-6px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .dl-option {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 14px;
    border-radius: 8px;
    font-size: 0.88rem;
    color: var(--text-primary);
    text-decoration: none;
    transition: background 100ms ease;
  }

  .dl-option:hover {
    background: var(--bg-surface-soft);
  }

  .dl-opt-icon {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    color: var(--text-muted);
  }

  /* Meta links */
  .hero-meta {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  .meta-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.82rem;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 120ms ease;
  }

  .meta-link:hover {
    color: var(--text-secondary);
  }

  /* Showcase */
  .showcase {
    width: 100%;
    margin-top: 56px;
  }

  .showcase-frame {
    width: 100%;
    aspect-ratio: 16 / 9.5;
    border-radius: 12px;
    border: 1px solid var(--border-strong);
    background: var(--bg-surface);
    overflow: hidden;
  }

  .showcase-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-muted);
  }

  /* Contributing card */
  .contrib-card {
    width: 100%;
    border: 1px solid var(--border-strong);
    border-radius: 12px;
    padding: 28px 32px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    margin-top: 40px;
  }

  .contrib-left {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    flex: 1;
    min-width: 0;
  }

  .contrib-icon {
    width: 22px;
    height: 22px;
    color: var(--text-secondary);
    flex-shrink: 0;
    margin-top: 3px;
  }

  .contrib-title {
    margin: 0 0 6px;
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-strong);
  }

  .contrib-desc {
    margin: 0;
    font-size: 0.82rem;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  .contrib-actions {
    display: flex;
    gap: 10px;
    flex-shrink: 0;
  }

  .contrib-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 18px;
    border-radius: 8px;
    font-size: 0.84rem;
    font-weight: 500;
    text-decoration: none;
    white-space: nowrap;
    transition: opacity 140ms ease;
  }

  .contrib-btn:hover {
    opacity: 0.75;
  }

  .contrib-btn-primary {
    background: var(--accent);
    color: var(--accent-contrast);
  }

  .contrib-btn-secondary {
    padding: 9px 18px;
    border: 1px solid var(--border-strong);
    color: var(--text-secondary);
    transition: background 120ms ease, color 120ms ease;
  }

  .contrib-btn-secondary:hover {
    background: var(--bg-surface-soft);
    color: var(--text-strong);
    opacity: 1;
  }

  @media (max-width: 767px) {
    .landing-wrap {
      padding: 60px 16px 48px;
    }

    .hero {
      padding: 24px 0 0;
    }

    .hero-title {
      font-size: clamp(1.8rem, 6vw, 2.6rem);
    }

    .hero-desc {
      font-size: 0.95rem;
    }

    .showcase {
      margin-top: 40px;
    }

    .contrib-card {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
