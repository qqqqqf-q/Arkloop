{
  "name": "@arkloop/desktop",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:electron": "node scripts/dev.mjs",
    "build": "pnpm build:web && pnpm build:electron",
    "build:web": "pnpm --filter web build",
    "build:electron": "tsc -p tsconfig.main.json && tsc -p tsconfig.preload.json",
    "pack": "pnpm build && electron-builder --dir",
    "dist": "pnpm build && electron-builder",
    "dist:mac": "pnpm build && electron-builder --mac",
    "dist:mac:arm64": "pnpm build && electron-builder --mac --arm64",
    "dist:mac:x64": "pnpm build && electron-builder --mac --x64",
    "dist:linux": "pnpm build && electron-builder --linux",
    "dist:win": "pnpm build && electron-builder --win",
    "dist:all": "pnpm build && electron-builder -mwl",
    "type-check": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.preload.json --noEmit"
  },
  "dependencies": {
    "electron-updater": "^6.6.2"
  },
  "devDependencies": {
    "@types/node": "^22.16.0",
    "electron": "^36.4.0",
    "electron-builder": "^26.0.12",
    "typescript": "~5.9.3"
  }
}
