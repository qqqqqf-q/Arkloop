ARKLOOP_POSTGRES_USER=arkloop
ARKLOOP_POSTGRES_PASSWORD=please_change_me
ARKLOOP_POSTGRES_DB=arkloop
ARKLOOP_POSTGRES_PORT=5432

# 集成测试使用的数据库连接
DATABASE_URL=postgresql://arkloop:please_change_me@127.0.0.1:5432/arkloop
ARKLOOP_DATABASE_URL=postgresql+asyncpg://arkloop:please_change_me@127.0.0.1:5432/arkloop

# 测试固定使用本地 stub 路由，避免命中真实 LLM
ARKLOOP_PROVIDER_ROUTING_JSON={"default_route_id":"default","credentials":[{"id":"stub_default","scope":"platform","provider_kind":"stub"}],"routes":[{"id":"default","model":"stub","credential_id":"stub_default"}]}

# 鉴权：JWT 签名密钥（至少 32 字符）
ARKLOOP_AUTH_JWT_SECRET=please_change_me_please_change_me_please_change_me

# Worker（Go）
ARKLOOP_WORKER_QUEUE_JOB_TYPES=run.execute

# 应用回调地址
ARKLOOP_APP_BASE_URL=http://localhost:5173

# Memory System (OpenViking)
# 留空跳过 MemoryMiddleware
ARKLOOP_OPENVIKING_BASE_URL=
ARKLOOP_OPENVIKING_ROOT_API_KEY=

# Browser Service
ARKLOOP_BROWSER_BASE_URL=
