ARKLOOP_POSTGRES_USER=arkloop
ARKLOOP_POSTGRES_PASSWORD=please_change_me
ARKLOOP_POSTGRES_DB=arkloop
# compose.dev.yaml 使用的宿主机映射端口；默认 compose 不暴露 Postgres
# Host-mapped port for compose.dev.yaml; default compose does not expose Postgres
ARKLOOP_POSTGRES_PORT=5432

# 应用侧连接串（后续数据层接入会读取）
# 默认直连 PostgreSQL；仅在启用可选 PgBouncer 层时改为池化地址
# Application-side connection string
# Connects directly to PostgreSQL; switch to pooled address when optional PgBouncer is enabled
DATABASE_URL=postgresql://arkloop:please_change_me@127.0.0.1:5432/arkloop
ARKLOOP_DATABASE_URL=postgresql://arkloop:please_change_me@127.0.0.1:5432/arkloop

# API：pgxpool 连接池（自部署默认值，SaaS/高并发场景可调高）
# API: pgxpool connection pool (self-hosted defaults; increase for SaaS/high-concurrency)
ARKLOOP_API_DB_POOL_MAX_CONNS=10
ARKLOOP_API_DB_POOL_MIN_CONNS=0
ARKLOOP_API_DB_DIRECT_POOL_MAX_CONNS=3
ARKLOOP_API_DB_DIRECT_POOL_MIN_CONNS=0
# 连接池统计日志间隔（秒），0 关闭 / Pool stats log interval (seconds), 0 to disable
ARKLOOP_API_DB_POOL_STATS_INTERVAL_SECONDS=10
# SSE 直连池 Acquire 超时（毫秒），0 关闭 / SSE direct pool acquire timeout (ms), 0 to disable
ARKLOOP_API_DIRECT_POOL_ACQUIRE_TIMEOUT_MS=200
# HTTP 入口并发上限，0 关闭 / HTTP max in-flight requests, 0 to disable
ARKLOOP_API_MAX_IN_FLIGHT=256

# 可选：PGBouncer 连接池（需要启用 pgbouncer compose profile）
# Optional: PGBouncer connection pool (requires pgbouncer compose profile)
# docker compose --profile pgbouncer up -d
ARKLOOP_PGBOUNCER_URL=postgresql://arkloop:please_change_me@127.0.0.1:5433/arkloop
# compose.dev.yaml 使用的宿主机映射端口；默认 compose 不暴露 PgBouncer
# Host-mapped port for compose.dev.yaml; default compose does not expose PgBouncer
ARKLOOP_PGBOUNCER_PORT=5433
ARKLOOP_PGBOUNCER_POOL_SIZE=200
ARKLOOP_PGBOUNCER_MAX_CLIENT_CONN=1000
# Docker Compose 默认业务流量直连 postgres；只有启用可选 PgBouncer 层时才覆盖
# Docker Compose routes traffic directly to postgres; override only when PgBouncer is enabled
# ARKLOOP_DOCKER_DATABASE_URL=postgresql://arkloop:please_change_me@pgbouncer:5432/arkloop

# SSE LISTEN/NOTIFY 专用直连 DSN（不经过 PgBouncer）
# 当 ARKLOOP_DATABASE_URL 或 ARKLOOP_DOCKER_DATABASE_URL 指向 PgBouncer 时必须配置此项
# 本地开发不配置（SSE 自动 fallback 到主连接）
# Dedicated direct DSN for SSE LISTEN/NOTIFY (bypasses PgBouncer)
# Required when DATABASE_URL points to PgBouncer; local dev falls back to main connection
# ARKLOOP_DATABASE_DIRECT_URL=postgresql://arkloop:please_change_me@127.0.0.1:5432/arkloop
# Docker Compose 默认直连 postgres；仅在需要与主连接拆分时覆盖
# Docker Compose connects directly to postgres; override only when splitting from main connection
# ARKLOOP_DOCKER_DATABASE_DIRECT_URL=postgresql://arkloop:please_change_me@postgres:5432/arkloop

# Redis（单实例，db number 逻辑隔离）
# Redis (single instance, db number for logical isolation)
ARKLOOP_REDIS_PASSWORD=please_change_me
# compose.dev.yaml 使用的宿主机映射端口；默认 compose 不暴露 Redis
# Host-mapped port for compose.dev.yaml; default compose does not expose Redis
ARKLOOP_REDIS_PORT=6379
ARKLOOP_REDIS_URL=redis://:please_change_me@127.0.0.1:6379/0
# Gateway 专用 Redis db（限流 / 访问日志 / IP 规则 / API Key 缓存 / 动态配置）
# 默认使用同一 Redis 实例的 db 1；SaaS/高并发场景可配置独立 Redis 实例
# Gateway-dedicated Redis db (rate limiting / access logs / IP rules / API key cache / dynamic config)
# Defaults to db 1 on the same instance; use a separate instance for SaaS/high-concurrency
ARKLOOP_GATEWAY_REDIS_URL=redis://:please_change_me@127.0.0.1:6379/1
# Gateway 请求路径 Redis 超时（毫秒） / Gateway request-path Redis timeout (ms)
# ARKLOOP_GATEWAY_REDIS_TIMEOUT_MS=10
# Gateway 是否信任上游传入的 X-Trace-Id（默认关闭）
# Whether Gateway trusts incoming X-Trace-Id (disabled by default)
# ARKLOOP_GATEWAY_TRUST_INCOMING_TRACE_ID=0
# Gateway CORS 允许的 Origin 列表（逗号分隔，默认本地 Web/Console/Console Lite）
# Gateway CORS allowed origins (comma-separated; defaults to local Web/Console/Console Lite)
# ARKLOOP_GATEWAY_CORS_ALLOWED_ORIGINS=http://localhost:19080,http://localhost:19081,http://localhost:19082
# 非 /v1 路径默认反代到当前启用的 Console 前端
# Non-/v1 paths are reverse-proxied to the active Console frontend
# ARKLOOP_GATEWAY_FRONTEND_UPSTREAM=http://console-lite:80

# Gateway 限流（token bucket） / Gateway rate limiting (token bucket)
# ARKLOOP_RATELIMIT_CAPACITY: burst 上限 / burst capacity (default 600)
# ARKLOOP_RATELIMIT_RATE_PER_MINUTE: 每分钟填充 token 数 / tokens refilled per minute (default 300)
# ARKLOOP_RATELIMIT_CAPACITY=600
# ARKLOOP_RATELIMIT_RATE_PER_MINUTE=300

# Storage / 存储
# 默认使用本地 filesystem 存储，适合单机/单节点自部署
# Defaults to local filesystem storage, suitable for single-node self-hosting
ARKLOOP_STORAGE_BACKEND=filesystem
ARKLOOP_STORAGE_ROOT=/var/lib/arkloop/storage
# 主业务 bucket 名；filesystem 后端同样复用该逻辑 bucket 名
# Primary bucket name; also used as logical bucket for filesystem backend
ARKLOOP_S3_BUCKET=arkloop
# 可选：切换到 SeaweedFS / S3-Compatible Object Storage 时使用
# Optional: used when switching to SeaweedFS / S3-compatible object storage
# ARKLOOP_S3_ACCESS_KEY=arkloop
# ARKLOOP_S3_SECRET_KEY=please_change_me
# ARKLOOP_S3_API_PORT=9000
# ARKLOOP_S3_ENDPOINT=http://127.0.0.1:9000
# ARKLOOP_S3_ENDPOINT_DOCKER=http://seaweedfs:8333
# ARKLOOP_S3_REGION=us-east-1
# ARKLOOP_S3_VOLUME_MAX=64

# 鉴权：JWT 签名密钥（至少 32 字符）
# Auth: JWT signing secret (at least 32 characters)
ARKLOOP_AUTH_JWT_SECRET=please_change_me_please_change_me_please_change_me
ARKLOOP_AUTH_ACCESS_TOKEN_TTL_SECONDS=900
ARKLOOP_AUTH_REFRESH_TOKEN_TTL_SECONDS=2592000
# compose.dev.yaml 使用的宿主机映射端口；默认 compose 只公开 Gateway
# Host-mapped ports for compose.dev.yaml; default compose only exposes Gateway
ARKLOOP_API_PORT=19001
ARKLOOP_GATEWAY_PORT=19000

# 加密密钥：API Key 等 secrets 用 AES-256-GCM 加密存储（64 位 hex / 32 字节）
# Encryption key: AES-256-GCM for API keys and secrets (64 hex chars / 32 bytes)
# 生成 / Generate: openssl rand -hex 32
ARKLOOP_ENCRYPTION_KEY=please_generate_with_openssl_rand_hex_32

# 管理员 bootstrap：API 启动时将该 user_id(UUID) 的用户提升为 platform_admin（一次性）
# 首次部署时设置，执行成功后可移除
# Admin bootstrap: promotes this user_id (UUID) to platform_admin on API startup (one-time)
# Set on first deploy; can be removed after successful execution
# ARKLOOP_BOOTSTRAP_PLATFORM_ADMIN=00000000-0000-0000-0000-000000000000

# Tool Providers / 工具提供者
ARKLOOP_TOOL_PROVIDER_CACHE_TTL_SECONDS=60

# 调试：把 LLM 输入/输出（raw chunk）写入 run_events（仅建议本地开启）
# Debug: write LLM raw input/output chunks to run_events (local dev only)
ARKLOOP_LLM_DEBUG_EVENTS=0

# Worker（Go）
# - 消费过滤：Worker 仅 lease 指定 job_type
# - Queue filter: Worker only leases the specified job types
ARKLOOP_WORKER_QUEUE_JOB_TYPES=run.execute
# 并发数（默认 4）/ Concurrent job goroutines (default 4)
# ARKLOOP_WORKER_CONCURRENCY=4

# Persona / MCP 配置 / Persona and MCP configuration
# persona 模板根目录，Docker 镜像中已内置；本地开发通常无需设置（自动推导）
# Root directory for persona templates; built into Docker images; auto-derived in local dev
# ARKLOOP_PERSONAS_ROOT=/usr/local/share/arkloop/personas
# MCP 配置文件路径（JSON）；未设置则跳过文件加载
# Path to MCP config file (JSON); skipped when not set
# ARKLOOP_MCP_CONFIG_FILE=./mcp.config.json

# 并发 run 上限（per org，默认 10）/ Max concurrent runs per org (default 10)
# ARKLOOP_LIMIT_CONCURRENT_RUNS=10

# LLM 请求重试（provider.retryable 错误，如 429/502/503）
# LLM request retry (provider.retryable errors, e.g. 429/502/503)
# - MAX_ATTEMPTS: 总尝试次数（含首次），默认 3 / Total attempts including first, default 3
# - BASE_DELAY_MS: 首次重试等待时长（毫秒），指数退避，上限 30s，默认 1000
#   First retry delay (ms), exponential backoff, capped at 30s, default 1000
ARKLOOP_LLM_RETRY_MAX_ATTEMPTS=3
ARKLOOP_LLM_RETRY_BASE_DELAY_MS=1000

# run_events 保留时长（月），超出后旧分区自动 DROP，默认 3
# run_events retention (months); older partitions are auto-dropped, default 3
ARKLOOP_RUN_EVENTS_RETENTION_MONTHS=3

# 邮件 / 回调地址优先通过 Console 管理（platform_settings）
# 如需无 Console 场景的临时兜底，可手动添加：
# Email / callback URLs are managed via Console (platform_settings)
# For fallback without Console, add manually:
# ARKLOOP_EMAIL_FROM=noreply@example.com
# ARKLOOP_APP_BASE_URL=http://localhost:19000
# 仅供本地开发/测试：允许显式 loopback HTTP base_url（如 http://127.0.0.1:8080）
# Local dev/test only: allow explicit loopback HTTP base_url (e.g. http://127.0.0.1:8080)
ARKLOOP_OUTBOUND_ALLOW_LOOPBACK_HTTP=false
# 自部署默认允许 Clash/Mihomo fake-ip 网段（198.18.0.0/15）；SaaS 请显式关闭
# Self-hosted default allows Clash/Mihomo fake-ip subnet (198.18.0.0/15); disable for SaaS
ARKLOOP_OUTBOUND_TRUST_FAKE_IP=true

# Cloudflare Turnstile 优先通过 Console 管理（platform_settings）
# 如需无 Console 场景的临时兜底，可手动添加：
# Cloudflare Turnstile is managed via Console (platform_settings)
# For fallback without Console, add manually:
# ARKLOOP_TURNSTILE_SECRET_KEY=
# ARKLOOP_TURNSTILE_SITE_KEY=
# ARKLOOP_TURNSTILE_ALLOWED_HOST=

# Memory System (OpenViking)
# OpenViking provider 统一通过 Console 的 Tools 页面管理；这里只保留服务本身所需的静态文件配置
# OpenViking provider is managed via Console Tools page; only static config kept here
# 如需强制覆盖 Worker 运行时地址，可临时手动添加：
# To force-override Worker runtime address, add manually:
# ARKLOOP_OPENVIKING_BASE_URL=http://openviking:19010
# ARKLOOP_OPENVIKING_ROOT_API_KEY=

# Sandbox Service
# Sandbox provider 地址统一通过 Console 的 Tools 页面管理
# Sandbox provider address is managed via Console Tools page
# 如需强制覆盖 Worker 运行时地址，可临时手动添加：
# To force-override Worker runtime address, add manually:
# ARKLOOP_SANDBOX_BASE_URL=http://sandbox-docker:19002
# 服务间认证 token（Worker -> Sandbox），生产环境必须配置
# Inter-service auth token (Worker -> Sandbox); must be set in production
# 生成 / Generate: openssl rand -hex 32
ARKLOOP_SANDBOX_AUTH_TOKEN=
# 是否在 Worker 中注册 browser 工具 / Register browser tool in Worker
# ARKLOOP_BROWSER_ENABLED=false
# 后端选择：firecracker（默认，需 Linux/KVM）或 docker（macOS/Windows/OSS 自部署）
# Backend: firecracker (default, requires Linux/KVM) or docker (macOS/Windows/self-hosted)
# ARKLOOP_SANDBOX_PROVIDER=firecracker
# 是否允许 Sandbox backend 访问外网 / Allow Sandbox backend egress
# ARKLOOP_SANDBOX_ALLOW_EGRESS=true
# Docker 后端使用的 sandbox-agent 容器镜像 / Docker backend sandbox-agent image
# ARKLOOP_SANDBOX_DOCKER_IMAGE=arkloop/sandbox-agent:dev
# Docker browser tier 使用的 sandbox-agent 容器镜像 / Docker browser tier image
# ARKLOOP_SANDBOX_BROWSER_DOCKER_IMAGE=arkloop/sandbox-browser:dev
# Docker 模式必须显式指定用户态 socket，禁止使用 /var/run/docker.sock
# Docker mode requires an explicit user-mode socket; /var/run/docker.sock is NOT allowed
# Linux rootless Docker: ARKLOOP_SANDBOX_DOCKER_SOCKET_PATH=/run/user/1000/docker.sock
# macOS Docker Desktop:  ARKLOOP_SANDBOX_DOCKER_SOCKET_PATH=/Users/yourname/.docker/run/docker.sock
# Windows WSL2 Docker Desktop: ARKLOOP_SANDBOX_DOCKER_SOCKET_PATH=/mnt/wsl/docker-desktop/shared-sockets/guest-services/docker.sock
# compose.dev.yaml 使用的宿主机映射端口；默认 compose 不暴露 Sandbox
# Host-mapped port for compose.dev.yaml; default compose does not expose Sandbox
# ARKLOOP_SANDBOX_PORT=19002
# ARKLOOP_SANDBOX_ADDR=0.0.0.0:19002
# ARKLOOP_FIRECRACKER_BIN=/usr/bin/firecracker
# ARKLOOP_SANDBOX_KERNEL_IMAGE=/opt/sandbox/vmlinux
# ARKLOOP_SANDBOX_ROOTFS=/opt/sandbox/rootfs.ext4
# ARKLOOP_SANDBOX_SOCKET_DIR=/run/sandbox
# ARKLOOP_SANDBOX_DOCKER_SOCKET_PATH=
# ARKLOOP_SANDBOX_EGRESS_INTERFACE=eth0
# ARKLOOP_SANDBOX_FIRECRACKER_TAP_PREFIX=arktap
# ARKLOOP_SANDBOX_FIRECRACKER_TAP_CIDR=172.29.0.0/16
# ARKLOOP_SANDBOX_FIRECRACKER_DNS=1.1.1.1,8.8.8.8
# ARKLOOP_SANDBOX_BOOT_TIMEOUT_SECONDS=30
# ARKLOOP_SANDBOX_AGENT_PORT=8080
# ARKLOOP_SANDBOX_MAX_SESSIONS=50
# ARKLOOP_SANDBOX_TEMPLATES_PATH=/opt/sandbox/templates.json
# ARKLOOP_SANDBOX_RESTORE_TTL_DAYS=7
# ARKLOOP_SANDBOX_SESSION_STATE_TTL_DAYS=7
# ARKLOOP_SANDBOX_FLUSH_DEBOUNCE_MS=2000
# ARKLOOP_SANDBOX_FLUSH_MAX_DIRTY_AGE_MS=15000
# ARKLOOP_SANDBOX_FLUSH_FORCE_BYTES_THRESHOLD=16777216
# ARKLOOP_SANDBOX_FLUSH_FORCE_COUNT_THRESHOLD=512

# Sandbox Warm Pool / Sandbox 预热池
ARKLOOP_SANDBOX_WARM_LITE=3
ARKLOOP_SANDBOX_WARM_PRO=2
ARKLOOP_SANDBOX_WARM_BROWSER=1
ARKLOOP_SANDBOX_WARM_ULTRA=1
ARKLOOP_SANDBOX_REFILL_INTERVAL=5
ARKLOOP_SANDBOX_REFILL_CONCURRENCY=2

# Sandbox Session Timeout（秒） / Sandbox session timeout (seconds)
ARKLOOP_SANDBOX_IDLE_TIMEOUT_LITE=180
ARKLOOP_SANDBOX_IDLE_TIMEOUT_PRO=300
ARKLOOP_SANDBOX_IDLE_TIMEOUT_BROWSER=120
ARKLOOP_SANDBOX_IDLE_TIMEOUT_ULTRA=600
ARKLOOP_SANDBOX_MAX_LIFETIME=1800
ARKLOOP_SANDBOX_MAX_LIFETIME_BROWSER=600

# ── Web Tools (Self-hosted) ─────────────────────────────────────
# 以下配置仅在启用 searxng/firecrawl compose profile 时需要
# 也可通过 Console UI 的 Tools 页面配置（platform_settings 表）
# Only needed when searxng/firecrawl compose profiles are enabled
# Can also be configured via Console UI Tools page (platform_settings)

# SearXNG: docker compose --profile searxng up -d
# 启动后配置 web_search provider / Configure web_search provider after startup:
# ARKLOOP_WEB_SEARCH_PROVIDER=searxng
# ARKLOOP_WEB_SEARCH_SEARXNG_BASE_URL=http://searxng:8080

# Firecrawl: docker compose --profile firecrawl up -d
# 启动后配置 web_fetch provider / Configure web_fetch provider after startup:
# ARKLOOP_WEB_FETCH_PROVIDER=firecrawl
# ARKLOOP_WEB_FETCH_FIRECRAWL_BASE_URL=http://firecrawl:19012
# ARKLOOP_FIRECRAWL_WORKERS=4
# ARKLOOP_FIRECRAWL_MAX_BROWSER_SESSIONS=5

# ── Test Overrides ──────────────────────────────────────────────
# cp .env.example .env.test && 按需修改以下变量
# Copy to .env.test and modify as needed; other values are inherited from .env
# 测试环境只需覆盖少量配置，其余继承 .env

# 集成测试数据库连接（asyncpg 驱动格式） / Integration test DB connection (asyncpg driver)
# ARKLOOP_DATABASE_URL=postgresql+asyncpg://arkloop:please_change_me@127.0.0.1:5432/arkloop

# stub 路由：避免命中真实 LLM / Stub routing: avoids hitting real LLM providers
# ARKLOOP_PROVIDER_ROUTING_JSON={"default_route_id":"default","credentials":[{"id":"stub_default","scope":"platform","provider_kind":"stub"}],"routes":[{"id":"default","model":"stub","credential_id":"stub_default"}]}
