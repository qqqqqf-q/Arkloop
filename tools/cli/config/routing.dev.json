{
  "default_route_id": "default",
  "credentials": [
    {
      "id": "stub_default",
      "scope": "platform",
      "provider_kind": "stub"
    },
    {
      "id": "platform_openai",
      "scope": "platform",
      "provider_kind": "openai",
      "api_key_env": "ARKLOOP_OPENAI_API_KEY",
      "base_url": "https://api.openai.com/v1",
      "openai_api_mode": "auto"
    },
    {
      "id": "platform_anthropic",
      "scope": "platform",
      "provider_kind": "anthropic",
      "api_key_env": "ARKLOOP_ANTHROPIC_API_KEY",
      "base_url": "https://api.anthropic.com/v1",
      "advanced_json": {}
    }
  ],
  "routes": [
    {
      "id": "default",
      "model": "stub",
      "credential_id": "stub_default",
      "when": {}
    },
    {
      "id": "openai",
      "model": "gpt-4.1-mini",
      "credential_id": "platform_openai",
      "when": {
        "route_id": "openai"
      }
    },
    {
      "id": "anthropic",
      "model": "claude-3-5-sonnet-latest",
      "credential_id": "platform_anthropic",
      "when": {
        "route_id": "anthropic"
      }
    }
  ]
}

